    {
      "cell_type": "code",
      "source": [
        "from Bio import Entrez\n",
        "import py3Dmol\n",
        "import requests\n",
        "import spacy\n",
        "from spacy.matcher import PhraseMatcher\n",
        "from collections import Counter\n",
        "import matplotlib.pyplot as plt"
      ],
      "metadata": {
        "id": "LFXJ4gJ8eyVZ"
      },
      "execution_count": 4,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "def search_pubchem(drug_name):\n",
        "    handle = Entrez.esearch(db=\"pccompound\", term=drug_name, retmax=1)\n",
        "    record = Entrez.read(handle)\n",
        "    handle.close()\n",
        "\n",
        "    if record[\"IdList\"]:\n",
        "        compound_id = record[\"IdList\"][0]\n",
        "        return compound_id\n",
        "    else:\n",
        "        return None"
      ],
      "metadata": {
        "id": "W1HZ9pKBfLlU"
      },
      "execution_count": 5,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "def search_pubmed_for_failed_trials(drug_name):\n",
        "    search_term = drug_name + \" AND clinical trial[tiab] AND (failure OR withdrawn OR terminated)\"\n",
        "    handle = Entrez.esearch(db=\"pubmed\", term=search_term, retmax=5)\n",
        "    record = Entrez.read(handle)\n",
        "    handle.close()\n",
        "\n",
        "    if record[\"IdList\"]:\n",
        "        print(\"PubMed Articles on Failed Clinical Trials for\", drug_name, \":\", record['IdList'])\n",
        "        return record[\"IdList\"]\n",
        "    else:\n",
        "        return []"
      ],
      "metadata": {
        "id": "DqgNUdBifNdt"
      },
      "execution_count": 6,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "def fetch_pubmed_abstracts(article_ids):\n",
        "    if not article_ids:\n",
        "        print(\"No abstracts found.\")\n",
        "        return []\n",
        "\n",
        "    handle = Entrez.efetch(db=\"pubmed\", id=\",\".join(article_ids), rettype=\"abstract\", retmode=\"text\")\n",
        "    abstracts = handle.read()\n",
        "    handle.close()\n",
        "\n",
        "    print(\"\\n Full Abstracts from PubMed:\")\n",
        "    print(abstracts)\n",
        "    return abstracts"
      ],
      "metadata": {
        "id": "InJNoXUIfpq4"
      },
      "execution_count": 7,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "def analyze_failure_reasons(text):\n",
        "    nlp = spacy.load(\"en_core_web_sm\")\n",
        "\n",
        "    # PhraseMatcher operates on token spans, not individual tokens,\n",
        "    # so multi-word terms like 'side effects' and 'FDA rejection' match correctly.\n",
        "    failure_terms = [\n",
        "    \"toxicity\", \"adverse\", \"mortality\", \"side effects\",\n",
        "    \"withdrawn\", \"terminated\", \"FDA rejection\", \"failure\"\n",
        "]\n",
        "    matcher = PhraseMatcher(nlp.vocab, attr=\"LOWER\")  # case-insensitive matching\n",
        "    matcher.add(\"FAILURE_TERMS\", [nlp.make_doc(t) for t in failure_terms])\n",
        "\n",
        "    # spaCy has a 1M character limit per doc; chunk if abstracts are large\n",
        "    max_chars = 900000\n",
        "    docs = [nlp(text[i:i+max_chars]) for i in range(0, len(text), max_chars)]\n",
        "\n",
        "    word_freq = Counter()\n",
        "    for doc in docs:\n",
        "        for _, start, end in matcher(doc):\n",
        "            word_freq[doc[start:end].text.lower()] += 1\n",
        "\n",
        "    print(\"\\n AI-Extracted Failure Reasons:\")\n",
        "    for word, freq in word_freq.items():\n",
        "        print(word, \":\", freq, \"occurrences\")\n",
        "\n",
        "    if word_freq:\n",
        "        plt.figure(figsize=(8, 5))\n",
        "        plt.bar(word_freq.keys(), word_freq.values(), color=\"blue\")\n",
        "        plt.title(\"Failure Reason Frequency in PubMed Abstracts\")\n",
        "        plt.xlabel(\"Failure Keywords\")\n",
        "        plt.ylabel(\"Frequency\")\n",
        "        plt.tight_layout()\n",
        "        plt.show()\n",
        "    else:\n",
        "        print(\"No failure terms detected in abstracts.\")"
      ],
      "metadata": {
        "id": "fM-lXOkdgG7L"
      },
      "execution_count": 8,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "def fetch_alphafold_structure(uniprot_id):\n",
        "    alphafold_url = f\"https://alphafold.ebi.ac.uk/files/AF-{uniprot_id}-F1-model_v6.pdb\"\n",
        "    response = requests.get(alphafold_url)\n",
        "\n",
        "    if response.status_code == 200:\n",
        "        print(\"AlphaFold PDB file found for UniProt ID:\", uniprot_id)\n",
        "        return response.text  # Returns the PDB file content\n",
        "    else:\n",
        "        return None"
      ],
      "metadata": {
        "id": "BjILW76ogwih"
      },
      "execution_count": 9,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "def visualize_alphafold_structure(pdb_content):\n",
        "    if not pdb_content:\n",
        "        print(\"No structure available for visualization.\")\n",
        "        return\n",
        "\n",
        "    viewer = py3Dmol.view(width=800, height=600)\n",
        "    viewer.addModel(pdb_content, \"pdb\")\n",
        "    viewer.setStyle({\"cartoon\": {\"color\": \"spectrum\"}})\n",
        "    viewer.zoomTo()\n",
        "    return viewer.show()"
      ],
      "metadata": {
        "id": "EnLJbPuNjL0g"
      },
      "execution_count": 10,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "def main():\n",
        "  Entrez.email = \"gsiako1@jhu.edu\"\n",
        "\n",
        "  drug_name = \"iniparib\"           # Failed PARP1 inhibitor; Phase III failure in GBM/TNBC\n",
        "  target_uniprot_id = \"P09874\"     # PARP1 (Poly [ADP-ribose] polymerase 1), Homo sapiens\n",
        "\n",
        "  compound_id = search_pubchem(drug_name)\n",
        "\n",
        "  failed_trial_articles = search_pubmed_for_failed_trials(drug_name)\n",
        "\n",
        "  if failed_trial_articles:\n",
        "      abstracts = fetch_pubmed_abstracts(failed_trial_articles)\n",
        "      analyze_failure_reasons(abstracts)\n",
        "\n",
        "  pdb_content = fetch_alphafold_structure(target_uniprot_id)\n",
        "  if pdb_content:\n",
        "      visualize_alphafold_structure(pdb_content)"
      ],
      "metadata": {
        "id": "0N-Ohf5jjadc"
      },
      "execution_count": 11,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "if __name__ == \"__main__\":\n",
        "  main()"
      ],
